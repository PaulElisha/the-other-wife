{
    "extends": "@tsconfig/node18/tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@base/*": [
                "./src/shared/base/*"
            ],
            "@app/*": [
                "./src/*"
            ],
            "@config/*": [
                "./src/config/*"
            ],
            "@model/*": [
                "./src/shared/model/*"
            ],
            "@error/*": [
                "src/shared/error/*"
            ],
            "@module/*": [
                "./src/modules/*"
            ],
            "@middleware/*": [
                "./src/shared/middleware/*"
            ],
            "@service/*": [
                "src/shared/external-service/*"
            ],
            "@enum/*": [
                "src/shared/enum/*"
            ],
            "@util/*": [
                "src/shared/util/*"
            ],
            "@constant/*": [
                "./src/constants/*"
            ],
            "@schema/*": [
                "./src/shared/zod-schema/*"
            ],
            "@template/*": [
                "./src/shared/template/*"
            ],
            "@type/*": [
                "./src/type/*"
            ]
        },
        "noEmit": true,
        "emitDecoratorMetadata": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "experimentalDecorators": true,
        "moduleResolution": "node",
        "module": "ES2022",
        "target": "ES2022",
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "strict": true
    },
    "include": [
        "src/**/*.ts",
        "api/**/*.ts",
        "src/@types/**/*.ts",
        "app.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}